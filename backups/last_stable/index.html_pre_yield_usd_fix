<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Bot Ultra-Premium</title>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Fira+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        body {
            background: radial-gradient(circle at top right, #0f172a, #020617);
            color: #f8fafc;
            font-family: 'Fira Sans', sans-serif;
            min-height: 100vh;
        }

        h1, h2, h3, .font-code { font-family: 'Fira Code', monospace; }

        .glass {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 4px 24px -1px rgba(0, 0, 0, 0.4);
        }

        .card-glow:hover {
            box-shadow: 0 0 40px rgba(59, 130, 246, 0.15);
            border-color: rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
            background: rgba(15, 23, 42, 0.6);
        }

        .tag-card {
            background: linear-gradient(145deg, #1e293b, #0f172a);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        input[type=number] { -moz-appearance: textfield; }

        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #3b82f6;
            border-radius: 10px;
        }

        @keyframes pulse-fast {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(0.98); }
        }
        .animate-pulse-fast { animation: pulse-fast 0.8s infinite ease-in-out; }
    </style>
    <audio id="alarm-sound" loop src="https://actions.google.com/sounds/v1/alarms/emergency_siren.ogg"></audio>
</head>

<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        const EquityChart = ({ data }) => {
            const chartRef = useRef(null);
            const chartInstance = useRef(null);

            useEffect(() => {
                if (chartRef.current && data && data.length > 0) {
                    if (chartInstance.current) chartInstance.current.destroy();
                    const ctx = chartRef.current.getContext('2d');
                    chartInstance.current = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.map(d => d.timestamp.split(' ')[1]),
                            datasets: [{
                                label: 'Patrimonio ARS',
                                data: data.map(d => d.value),
                                borderColor: '#22d3ee',
                                backgroundColor: 'rgba(34, 211, 238, 0.1)',
                                borderWidth: 3,
                                pointRadius: 0,
                                fill: true,
                                tension: 0.4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } } },
                                x: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } } }
                            }
                        }
                    });
                }
            }, [data]);

            return <canvas ref={chartRef}></canvas>;
        };

        function App() {
            const [status, setStatus] = useState({ positions: {}, opportunities: {}, history: [], balances: {}, equity_history: [] });
            const [config, setConfig] = useState({ strategy: {}, watchlist: [] });
            const [editConfig, setEditConfig] = useState(null);
            const [newSymbol, setNewSymbol] = useState("");
            const [notification, setNotification] = useState({ show: false, message: "", type: "info" });

            const fetchStatus = async () => {
                try {
                    const res = await fetch('/api/status');
                    const data = await res.json();
                    setStatus(data);
                } catch (e) { console.error(e); }
            };

            const fetchConfig = async () => {
                try {
                    const res = await fetch('/api/config');
                    const data = await res.json();
                    setConfig(data);
                    setEditConfig(data);
                } catch (e) { console.error(e); }
            };

            const saveConfig = async () => {
                await fetch('/api/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(editConfig)
                });
                setNotification({ show: true, message: "✅ Configuración guardada y aplicada.", type: "success" });
                fetchConfig();
            };

            const syncHistory = async () => {
                setNotification({ show: true, message: "Sincronizando con IOL...", type: "info" });
                const res = await fetch('/api/sync_history', { method: 'POST' });
                const data = await res.json();
                setNotification({ show: true, message: data.message, type: 'success' });
                fetchStatus();
            };

            const cancelSL = async (symbol) => {
                await fetch(`/api/cancel_sl?symbol=${symbol}`, { method: 'POST' });
                fetchStatus();
            };

            const manualBuy = async (symbol) => {
                if (!confirm(`¿Comprar ${symbol}?`)) return;
                const res = await fetch(`/api/buy?symbol=${symbol}`, { method: 'POST' });
                const data = await res.json();
                setNotification({ show: true, message: data.message, type: data.status === 'success' ? 'success' : 'error' });
                fetchStatus();
            };

            const addSymbol = async () => {
                if (!newSymbol) return;
                const res = await fetch(`/api/add_symbol?symbol=${newSymbol.toUpperCase()}`, { method: 'POST' });
                const data = await res.json();
                setNewSymbol('');
                fetchConfig();
                setNotification({ show: true, message: data.message, type: 'success' });
            };

            useEffect(() => {
                fetchStatus(); fetchConfig();
                const interval = setInterval(fetchStatus, 5000);
                return () => clearInterval(interval);
            }, []);

            useEffect(() => {
                const anyPending = Object.values(status.positions || {}).some(p => p.pending_sl);
                const sound = document.getElementById('alarm-sound');
                if (sound) {
                    if (anyPending) sound.play().catch(() => {});
                    else { sound.pause(); sound.currentTime = 0; }
                }
            }, [status.positions]);

            const securedProfit = Object.values(status.positions || {}).reduce((acc, pos) => {
                if (pos.step > 0) return acc + ((pos.sl - pos.entry_price) * pos.qty * (pos.multiplier || 1));
                return acc;
            }, 0);

            return (
                <div className="max-w-[1800px] mx-auto p-6 space-y-8">
                    {/* NOTIFICATION */}
                    {notification.show && (
                        <div className={`fixed top-10 left-1/2 -translate-x-1/2 z-[100] px-8 py-4 rounded-2xl border backdrop-blur-xl shadow-2xl transition-all duration-500 ${notification.type === 'success' ? 'bg-green-500/10 border-green-500/20 text-green-400' : 'bg-blue-500/10 border-blue-500/20 text-blue-400'}`}>
                            <span className="text-sm font-black font-code">{notification.message}</span>
                            <button onClick={() => setNotification({ ...notification, show: false })} className="ml-4 text-xs opacity-50">✕</button>
                        </div>
                    )}

                    {/* PREMIUM HEADER */}
                    <header className="flex flex-col gap-8">
                        <div className="flex justify-between items-center">
                            <div>
                                <h1 className="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400 tracking-tighter uppercase italic font-code">Trading Agent <span className="text-white not-italic">Pro</span></h1>
                                <div className="flex items-center gap-3 mt-1 text-slate-500 font-bold uppercase tracking-[0.2em] text-[9px] font-code">
                                    <span className="flex h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse"></span>
                                    Sistema de Alta Frecuencia Activo
                                </div>
                            </div>
                            <div className="flex gap-4">
                                <button 
                                    onClick={async () => {
                                        const newAuto = !config.auto_buy;
                                        await fetch('/api/config', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({...config, auto_buy: newAuto}) });
                                        fetchConfig();
                                    }}
                                    className={`px-8 py-4 rounded-2xl font-black uppercase text-[10px] border tracking-widest transition-all shadow-2xl font-code ${config.auto_buy ? 'bg-indigo-600/10 border-indigo-500/50 text-indigo-400' : 'bg-red-600 text-white animate-pulse'}`}
                                >
                                    {config.auto_buy ? '🤖 AUTO: ON' : '👤 MANUAL'}
                                </button>
                                <button 
                                    onClick={async () => {
                                        const newStatus = !config.trading_paused;
                                        await fetch('/api/config', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({...config, trading_paused: newStatus}) });
                                        fetchConfig();
                                    }}
                                    className={`px-8 py-4 rounded-2xl font-black text-[10px] uppercase border tracking-widest transition-all font-code ${config.trading_paused ? 'bg-red-600 text-white' : 'bg-slate-900 text-slate-500 border-slate-800'}`}
                                >
                                    {config.trading_paused ? '🚨 REANUDAR' : '🛡️ PAUSAR'}
                                </button>
                            </div>
                        </div>

                        {/* GLOBAL PERFORMANCE BAR - COMPACTADO */}
                        <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                            {/* FILA 1 - COMPACTA */}
                            <div className="glass p-5 rounded-[2rem] border border-indigo-500/20 bg-indigo-500/[0.02]">
                                <span className="text-[11px] font-black text-indigo-400 uppercase tracking-[0.4em] mb-1 block font-code">Inversión Inicial</span>
                                <div className="text-3xl font-black text-white font-code tracking-tighter text-right">${Math.round(config.strategy?.total_invested || 0).toLocaleString()}</div>
                                <div className="text-[11px] font-bold text-emerald-400 font-code mt-1 text-right">u$d {Math.round(config.strategy?.total_invested_usd || 0).toLocaleString()} <span className="text-[8px] text-slate-500">(Hist.)</span></div>
                            </div>
                            
                            <div className="glass p-5 rounded-[2rem] border border-cyan-500/20 bg-cyan-500/[0.02]">
                                <span className="text-[11px] font-black text-cyan-400 uppercase tracking-[0.4em] mb-1 block font-code">Patrimonio Real</span>
                                <div className="text-3xl font-black text-white font-code tracking-tighter text-right">${Math.round(status.balances?.total_pesos || 0).toLocaleString()}</div>
                                <div className="text-[11px] font-bold text-emerald-400 font-code mt-1 text-right">u$d {Math.round(status.balances?.total_usd || 0).toLocaleString()} (Hoy)</div>
                            </div>

                            <div className={`glass p-5 rounded-[2rem] border ${status.balances?.total_pesos >= config.strategy?.total_invested ? 'border-emerald-500/20 bg-emerald-500/[0.02]' : 'border-rose-500/20 bg-rose-500/[0.02]'}`}>
                                <span className="text-[11px] font-black uppercase tracking-[0.4em] mb-1 block font-code text-slate-400">Rendimiento Global</span>
                                <div className={`text-3xl font-black font-code tracking-tighter text-right ${status.balances?.total_pesos >= config.strategy?.total_invested ? 'text-emerald-400' : 'text-rose-400'}`}>
                                    {(((status.balances?.total_pesos || 0) / (config.strategy?.total_invested || 1) - 1) * 100).toFixed(2)}%
                                </div>
                                <div className="text-[9px] font-bold text-slate-500 font-code mt-1 text-right">ARS</div>
                            </div>

                            {/* FILA 2 - MÁS COMPACTA */}
                            <div className="glass p-4 rounded-3xl border border-blue-500/20 bg-blue-500/[0.02]">
                                <span className="text-[11px] font-black text-blue-400 uppercase tracking-[0.4em] mb-1 block font-code">Efectivo (T0)</span>
                                <div className="text-2xl font-black text-white font-code tracking-tighter text-right">${Math.round(status.balances?.t0 || 0).toLocaleString()}</div>
                            </div>

                            <div className="glass p-4 rounded-3xl border border-slate-800/50">
                                <span className="text-[11px] font-black text-slate-500 uppercase tracking-[0.4em] mb-1 block font-code">A Liquidar (T2)</span>
                                <div className="text-2xl font-black text-slate-300 font-code tracking-tighter text-right">${Math.round(status.balances?.t2 || 0).toLocaleString()}</div>
                            </div>

                            {/* 6. PROFIT PROYECTADO */}
                            {(() => {
                                const unrealizedProfit = Object.values(status.positions || {}).reduce((acc, pos) => {
                                    const current = pos.current_price || pos.entry_price;
                                    return acc + ((current - pos.entry_price) * pos.qty * (pos.multiplier || 1));
                                }, 0);
                                const isPositive = unrealizedProfit >= 0;

                                return (
                                    <div className={`glass p-4 rounded-3xl border ${isPositive ? 'border-emerald-500/20 bg-emerald-500/[0.02]' : 'border-rose-500/20 bg-rose-500/[0.02]'}`}>
                                        <span className={`text-[11px] font-black uppercase tracking-[0.4em] mb-1 block font-code ${isPositive ? 'text-emerald-400' : 'text-rose-400'}`}>Profit Proyectado</span>
                                        <div className={`text-2xl font-black font-code tracking-tighter text-right ${isPositive ? 'text-emerald-400' : 'text-rose-400'}`}>
                                            ${Math.round(unrealizedProfit).toLocaleString()}
                                        </div>
                                        <div className="text-[9px] font-bold text-blue-400/50 font-code mt-1 text-right italic">Asegurado: ${Math.round(securedProfit).toLocaleString()}</div>
                                    </div>
                                );
                            })()}
                        </div>
                    </header>

                    {/* ALERTS */}
                    {Object.entries(status.positions || {}).filter(([_, p]) => p.pending_sl).map(([sym, p]) => (
                        <div key={sym} className="bg-red-600 p-10 rounded-[3rem] flex justify-between items-center shadow-2xl animate-pulse">
                            <div>
                                <h2 className="text-4xl font-black italic uppercase text-white">⚠️ ALERTA: {sym} tocó piso</h2>
                                <p className="text-red-100 font-bold uppercase tracking-widest mt-1">Venta automática en {p.sl_countdown}s</p>
                            </div>
                            <button onClick={() => cancelSL(sym)} className="bg-white text-red-600 px-12 py-6 rounded-2xl text-xl font-black uppercase hover:scale-105 transition-all">CANCELAR VENTA</button>
                        </div>
                    ))}

                    {/* CARTERA ACTIVA */}
                    <section className="space-y-6">
                        <h2 className="text-3xl font-black font-code tracking-tighter uppercase italic border-l-8 border-blue-500 pl-6">Cartera Activa</h2>
                        <div className="grid grid-cols-1 gap-6">
                            {Object.entries(status.positions || {}).map(([sym, pos]) => {
                                const current = pos.current_price || pos.entry_price;
                                const win = current >= pos.entry_price;
                                const profit_val = (current - pos.entry_price) * pos.qty * (pos.multiplier || 1);

                                return (
                                    <div key={sym} className="glass p-6 rounded-[2.5rem] border border-slate-800/50 flex items-center gap-8 card-glow transition-all relative overflow-hidden group">
                                        <div className={`absolute left-0 top-0 h-full w-2 ${win ? 'bg-green-500' : 'bg-red-500'}`}></div>
                                        
                                        <div className="flex-1">
                                            <div className="flex items-center gap-4 mb-2">
                                                <span className="text-5xl font-black tracking-tighter uppercase italic font-code text-white">{sym}</span>
                                                <div className="flex gap-2">
                                                    <span className={`text-[10px] px-3 py-1 font-black rounded-lg font-code border ${pos.step > 0 ? 'bg-yellow-400/20 text-yellow-400 border-yellow-400/30' : 'bg-slate-800 text-slate-500 border-slate-700'}`}>
                                                        {pos.step > 1 ? '🔥' : '🧊'} SALTOS: {pos.step || 0}
                                                    </span>
                                                </div>
                                            </div>
                                            <div className="flex gap-6 text-[12px] font-code font-bold text-slate-400 uppercase tracking-tighter">
                                                <span>Entrada: ${pos.entry_price.toLocaleString()}</span>
                                                <span>Qty: {pos.qty}</span>
                                                <span className="text-white">Total: ${Math.round(current * pos.qty * (pos.multiplier || 1)).toLocaleString()}</span>
                                            </div>
                                        </div>

                                        <div className="flex-[1.5] px-10 text-center">
                                            <div className="flex justify-between text-[10px] text-slate-500 font-black uppercase mb-2 font-code">
                                                <span>PISO: ${Math.round(pos.sl).toLocaleString()}</span>
                                                <span>TECHO: ${Math.round(pos.tp).toLocaleString()}</span>
                                            </div>
                                            <div className="h-3 bg-slate-950 rounded-full relative overflow-hidden border border-slate-900 shadow-inner">
                                                <div className="absolute top-0 bottom-0 left-0 bg-gradient-to-r from-red-500/20 via-transparent to-green-500/20 w-full"></div>
                                                <div className="absolute top-0 bottom-0 w-1.5 bg-yellow-400 shadow-[0_0_15px_#facc15]" style={{ left: `${Math.min(Math.max(((current - pos.sl) / (pos.tp - pos.sl)) * 100, 0), 100)}%` }}></div>
                                            </div>
                                            <div className="text-xs font-black text-yellow-400 font-code mt-1 tracking-widest">${current.toLocaleString()}</div>
                                        </div>

                                        <div className="w-64 text-right">
                                            <div className={`text-4xl font-black font-code tracking-tighter ${win ? 'text-green-400' : 'text-red-400'}`}>
                                                {win ? '+' : ''}${Math.round(profit_val).toLocaleString()}
                                            </div>
                                            <div className={`text-sm font-bold font-code ${win ? 'text-green-400' : 'text-red-400'}`}>
                                                {win ? '▲' : '▼'} {pos.profit_pct?.toFixed(2)}%
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </section>

                    {/* CONFIGURACIÓN Y RADAR */}
                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-10">
                        {/* MOTOR DE AJUSTES */}
                        <div className="glass p-10 rounded-[3rem] border border-slate-800/50">
                            <div className="flex items-center justify-between mb-8 border-b border-slate-800/50 pb-6">
                                <div className="flex items-center gap-4">
                                    <div className="h-12 w-12 rounded-2xl bg-blue-500/10 flex items-center justify-center border border-blue-500/20 text-blue-400">
                                        <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                                    </div>
                                    <div>
                                        <h2 className="text-2xl font-black text-white uppercase tracking-tighter font-code">Configuración</h2>
                                        <div className="flex gap-2 mt-2">
                                            {[
                                                {id: 'agresivo', label: '🚀 AGRESIVO', color: 'rose'},
                                                {id: 'normal', label: '⚖️ NORMAL', color: 'blue'},
                                                {id: 'conservador', label: '🛡️ CONSERVADOR', color: 'emerald'}
                                            ].map(mode => (
                                                <button 
                                                    key={mode.id}
                                                    onClick={() => {
                                                        const presets = {
                                                            agresivo: { initial_sl_pct: 0.99, initial_tp_pct: 1.015, trailing_sl_pct: 0.995, trailing_tp_pct: 1.01 },
                                                            normal: { initial_sl_pct: 0.98, initial_tp_pct: 1.03, trailing_sl_pct: 0.988, trailing_tp_pct: 1.015 },
                                                            conservador: { initial_sl_pct: 0.96, initial_tp_pct: 1.08, trailing_sl_pct: 0.97, trailing_tp_pct: 1.03 }
                                                        };
                                                        setEditConfig({...editConfig, trading_mode: mode.id, strategy: {...editConfig.strategy, ...presets[mode.id]}});
                                                    }}
                                                    className={`px-3 py-1.5 rounded-lg text-[9px] font-black uppercase tracking-wider transition-all border ${editConfig?.trading_mode === mode.id ? `bg-${mode.color}-500/20 border-${mode.color}-500 text-${mode.color}-400` : 'bg-slate-900 border-slate-800 text-slate-500'}`}
                                                >
                                                    {mode.label}
                                                </button>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                <button onClick={saveConfig} className="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-2xl font-black text-[10px] uppercase tracking-widest transition shadow-lg shadow-blue-500/20 font-code">Guardar</button>
                            </div>

                            {editConfig && (
                                <div className="grid grid-cols-2 gap-6">
                                    <div className="bg-slate-950/40 p-5 rounded-3xl border border-slate-900/50">
                                        <label className="text-[9px] font-black text-slate-600 uppercase mb-2 block tracking-widest">Stop Loss (%)</label>
                                        <input type="number" step="0.1" value={Math.round((1 - (editConfig.strategy?.initial_sl_pct || 0.98)) * 1000)/10} onChange={e => setEditConfig({...editConfig, strategy: {...editConfig.strategy, initial_sl_pct: 1 - (e.target.value/100)}})} className="w-full bg-slate-900 p-3 rounded-xl text-white font-code text-lg outline-none border border-slate-800 focus:border-indigo-500" />
                                    </div>
                                    <div className="bg-slate-950/40 p-5 rounded-3xl border border-slate-900/50">
                                        <label className="text-[9px] font-black text-slate-600 uppercase mb-2 block tracking-widest">Take Profit (%)</label>
                                        <input type="number" step="0.1" value={Math.round(((editConfig.strategy?.initial_tp_pct || 1.015) - 1) * 1000)/10} onChange={e => setEditConfig({...editConfig, strategy: {...editConfig.strategy, initial_tp_pct: 1 + (e.target.value/100)}})} className="w-full bg-slate-900 p-3 rounded-xl text-white font-code text-lg outline-none border border-slate-800 focus:border-emerald-500" />
                                    </div>
                                    <div className="bg-slate-950/40 p-5 rounded-3xl border border-slate-900/50">
                                        <label className="text-[9px] font-black text-slate-600 uppercase mb-2 block tracking-widest">Estrategia EOD</label>
                                        <select value={editConfig.strategy?.eod_strategy || "off"} onChange={e => setEditConfig({...editConfig, strategy: {...editConfig.strategy, eod_strategy: e.target.value}})} className="w-full bg-slate-900 p-3 rounded-xl text-white font-code text-sm outline-none border border-slate-800">
                                            <option value="off">🚫 OFF</option>
                                            <option value="selective">🎯 SELECTIVE</option>
                                            <option value="full">💣 FULL</option>
                                        </select>
                                    </div>
                                    <div className="bg-slate-950/40 p-5 rounded-3xl border border-slate-900/50">
                                        <label className="text-[9px] font-black text-slate-600 uppercase mb-2 block tracking-widest">Profit EOD (%)</label>
                                        <input type="number" step="0.1" value={editConfig.strategy?.eod_profit_threshold || 1.5} onChange={e => setEditConfig({...editConfig, strategy: {...editConfig.strategy, eod_profit_threshold: parseFloat(e.target.value)}})} className="w-full bg-slate-900 p-3 rounded-xl text-white font-code text-lg outline-none border border-slate-800 focus:border-rose-500" />
                                    </div>
                                </div>
                            )}
                        </div>

                        {/* RADAR */}
                        <div className="glass p-10 rounded-[3rem] border border-slate-800/50 flex flex-col">
                            <h3 className="text-xl font-black text-blue-400 font-code uppercase italic mb-8 border-b border-slate-800/50 pb-4">🔭 Radar de Oportunidades</h3>
                            <div className="space-y-4 overflow-y-auto max-h-[400px] pr-2 custom-scrollbar">
                                {Object.entries(status.opportunities || {}).sort((a,b) => b[1].score - a[1].score).map(([sym, opt]) => (
                                    <div key={sym} className="bg-slate-950/40 p-5 rounded-2xl border border-slate-900/50 flex justify-between items-center group hover:bg-blue-500/5 transition-all">
                                        <div className="flex flex-col">
                                            <span className="text-2xl font-black font-code italic uppercase text-slate-300 group-hover:text-blue-400 transition">{sym}</span>
                                            <span className="text-[10px] text-slate-600 font-black">${opt.price?.toLocaleString()}</span>
                                        </div>
                                        <div className="flex items-center gap-4">
                                            <span className="text-3xl font-black font-code text-blue-400">{opt.score?.toFixed(1)}</span>
                                            <button onClick={() => manualBuy(sym)} className="bg-green-500/10 text-green-500 border border-green-500/20 px-6 py-2 rounded-xl text-[10px] font-black uppercase hover:bg-green-500 hover:text-black transition">BUY</button>
                                        </div>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>

                    {/* WATCHLIST */}
                    <section className="glass p-10 rounded-[3rem] border border-slate-800/50">
                        <div className="flex justify-between items-center mb-8 border-b border-slate-800/30 pb-6">
                            <h3 className="text-2xl font-black text-white font-code uppercase italic tracking-tighter">Símbolos Activos</h3>
                            <div className="flex gap-2 bg-slate-950 p-1 rounded-xl border border-slate-900">
                                <input type="text" value={newSymbol} onChange={e => setNewSymbol(e.target.value.toUpperCase())} placeholder="SÍMBOLO..." className="bg-transparent text-sm font-black text-white px-4 py-2 outline-none w-32 font-code" />
                                <button onClick={addSymbol} className="bg-blue-600 px-6 py-2 rounded-lg text-white font-black text-xs">+</button>
                            </div>
                        </div>
                        <div className="flex flex-wrap gap-3">
                            {(editConfig?.watchlist || []).map(s => (
                                <div key={s} className="tag-card px-5 py-3 rounded-2xl flex items-center gap-4 group hover:border-blue-500/30 transition-all">
                                    <span className="text-sm font-black text-slate-300 group-hover:text-white font-code">{s}</span>
                                    <button onClick={() => setEditConfig({...editConfig, watchlist: editConfig.watchlist.filter(x => x !== s)})} className="h-6 w-6 rounded-full bg-slate-900 border border-slate-800 text-xs text-slate-600 hover:bg-red-600/20 hover:text-red-400 transition">×</button>
                                </div>
                            ))}
                        </div>
                    </section>

                    {/* HISTORY */}
                    <section className="glass rounded-[3rem] border border-slate-800/50 overflow-hidden shadow-2xl">
                        <div className="p-10 border-b border-slate-800/50 flex justify-between items-center bg-slate-900/20">
                            <h2 className="text-3xl font-black italic uppercase tracking-tighter font-code">📜 Historial</h2>
                            <button onClick={syncHistory} className="bg-blue-600 text-white px-10 py-4 rounded-2xl font-black text-[12px] uppercase tracking-widest font-code">Sincro IOL</button>
                        </div>
                        <div className="overflow-x-auto max-h-[500px] custom-scrollbar">
                            <table className="w-full text-sm text-left">
                                <thead className="bg-slate-950 sticky top-0 text-slate-500 text-[11px] uppercase font-black tracking-widest border-b border-slate-800">
                                    <tr>
                                        <th className="px-10 py-8">Fecha</th>
                                        <th className="px-10 py-8">Símbolo</th>
                                        <th className="px-10 py-8 text-right">Profit (%)</th>
                                        <th className="px-10 py-8 text-right">Profit ($)</th>
                                    </tr>
                                </thead>
                                <tbody className="divide-y divide-slate-800/30">
                                    {(status.history || []).slice().sort((a, b) => b.date.localeCompare(a.date)).map((h, i) => (
                                         <tr key={i} className="hover:bg-blue-400/[0.02]">
                                             <td className="px-10 py-6 text-slate-500 font-mono text-[12px]">{h.date}</td>
                                             <td className="px-10 py-6 text-2xl font-black italic">{h.symbol}</td>
                                             <td className={`px-10 py-6 text-right font-black ${h.profit_pct >= 0 ? 'text-green-400' : 'text-red-400'}`}>{h.profit_pct?.toFixed(2)}%</td>
                                             <td className={`px-10 py-6 text-right font-black text-xl ${h.profit_amount >= 0 ? 'text-green-400' : 'text-red-400'}`}>${Math.round(h.profit_amount || 0).toLocaleString()}</td>
                                         </tr>
                                     ))}
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>